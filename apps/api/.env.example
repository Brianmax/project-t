# --- Auth ---
JWT_ACCESS_SECRET=change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Admin seed ---
ADMIN_EMAIL=admin@propmanager.local
ADMIN_PASSWORD=changeme123

# --- Phase 04: Receipt PDF generation ---
# Feature flag — when false, the PDF endpoints respond 404 FEATURE_DISABLED
# and the BullMQ worker does not register.
RECEIPT_PDF_ENABLED=false

# Storage (S3-compatible — MinIO in dev, AWS S3 in prod)
# In production, unset AWS_S3_ENDPOINT and provide real AWS creds.
AWS_S3_BUCKET=receipts
AWS_S3_ENDPOINT=http://localhost:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
STORAGE_URL_TTL_SECONDS=300

# Job queue (BullMQ on Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
